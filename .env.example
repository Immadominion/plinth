# Database
DATABASE_URL=postgres://nomba:nomba_dev@localhost:5432/nomba_subs

# Redis (for BullMQ — omit to use in-memory fake)
REDIS_URL=redis://localhost:6379

# Server
PORT=3000
NODE_ENV=development

# Nomba API (leave blank to use FakeNombaAdapter)
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
NOMBA_ACCOUNT_ID=
NOMBA_BASE_URL=https://sandbox.nomba.com
NOMBA_WEBHOOK_SECRET=

# Set to false to use HttpNombaAdapter (requires keys above)
USE_FAKE_NOMBA=true

# Logging
LOG_LEVEL=info
